# ── 네이버 로그인 OAuth2 (개발자센터 애플리케이션) ──
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 관리계정(4213) 소유자 네이버 로그인으로 1회 발급 (tools.get_refresh_token 참고)
NAVER_REFRESH_TOKEN=
NAVER_MANAGER_ACCOUNT_NO=4213

# ── 네이버 GFA ad-api ──
NAVER_API_BASE=https://openapi.naver.com/v1/ad-api
NAVER_API_VERSION=1
NAVER_TOKEN_URL=https://nid.naver.com/oauth2.0/token
# get_refresh_token 최초 발급 시 사용 (개발자센터에 등록한 Callback URL과 일치해야 함)
NAVER_REDIRECT_URI=http://localhost:8080/callback

# ── DB ──
DATABASE_URL=postgresql+psycopg://navergfa:navergfa@localhost:5432/navergfa

# ── API 키 해시용 서버 pepper (임의의 긴 랜덤 문자열) ──
API_KEY_PEPPER=change-me-to-a-long-random-secret

# ── 운영자 콘솔 ──
ADMIN_TOKEN=set-a-strong-admin-password
GITHUB_REPO=Jhongjin/Naver_Gfa
# (선택) 콘솔의 '전체 이름 보강' 버튼이 Actions 를 트리거하려면 actions:write PAT
GITHUB_DISPATCH_TOKEN=
